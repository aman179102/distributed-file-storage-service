# =============================================================================
# Distributed File Storage Service - Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All settings have sensible defaults for local development.
# =============================================================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=15s
CORS_ORIGINS=*
RATE_LIMIT_PER_IP=100
RATE_LIMIT_PER_USER=1000
MAX_BODY_SIZE_MB=5120
API_BASE_PATH=/api/v1

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=filestore
DB_PASSWORD=filestore
DB_NAME=filestore
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_MIGRATIONS_DIR=src/infrastructure/database/migrations

# --- Storage ---
STORAGE_DATA_DIR=/data/storage
STORAGE_CHUNK_SIZE_MB=64
STORAGE_REPLICATION_FACTOR=3
STORAGE_DATA_SHARDS=4
STORAGE_PARITY_SHARDS=2
STORAGE_MAX_FILE_SIZE_GB=512
STORAGE_TEMP_DIR=/tmp/filestore

# --- Auth ---
AUTH_JWT_SECRET=change-me-in-production-please
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_BCRYPT_COST=12
AUTH_DEFAULT_ADMIN_USER=admin
AUTH_DEFAULT_ADMIN_PASSWORD=admin123

# --- Metrics ---
METRICS_ENABLED=true
METRICS_PATH=/metrics

# --- Tracing ---
TRACING_ENABLED=false
TRACING_SERVICE_NAME=distributed-file-storage
TRACING_ENDPOINT=http://localhost:4318
TRACING_SAMPLE_RATE=0.1

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
